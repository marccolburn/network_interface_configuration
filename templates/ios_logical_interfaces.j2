{% for interface in logical_interfaces %}
{% if interface.unit is defined %}
interface {{ interface.name }}.{{ interface.unit }}
  encapsulation dot1q {{ interface.unit }}
  ip address {{ interface['ipv4'][0]['address'] }} {{ interface['ipv4'][0]['mask'] }}
{% else %}
interface {{ interface.name }}
  ip address {{ interface['ipv4'][0]['address'] }} {{ interface['ipv4'][0]['mask'] }}
{% endif %}
{% endfor %}
